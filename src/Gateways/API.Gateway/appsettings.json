{
  "ReverseProxy": {
    "Routes": {
      "users-api": {
        "ClusterId": "users-api-cluster",
        "Match": {
          "Path": "/users/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/users" }
        ]
      },
      "corejudge-api": {
        "ClusterId": "corejudge-api-cluster",
        "Match": {
          "Path": "/corejudge/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/corejudge" }
        ]
      }
    },
    "Clusters": {
      "users-api-cluster": {
        "Destinations": {
          "users-api": {
            "Address": "http://users.api:8080/"
          }
        }
      },
      "corejudge-api-cluster": {
        "Destinations": {
          "corejudge-api": {
            "Address": "http://corejudge.api:8080/"
          }
        }
      }
    }
  }
}