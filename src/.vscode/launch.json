{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (CoreJudge.API)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-CoreJudge.API",
            "program": "${workspaceFolder}/Services/CoreJudge/CoreJudge.API/bin/Debug/net8.0/CoreJudge.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Services/CoreJudge/CoreJudge.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5151"
            }
        },
        {
            "name": ".NET Core Launch (Users.API)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-Users.API",
            "program": "${workspaceFolder}/Services/Users/User.API/bin/Debug/net8.0/Users.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Services/Users/User.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5009"
            }
        }
    ],
    "compounds": [
        {
            "name": "Run CoreJudge + Users APIs",
            "configurations": [
                ".NET Core Launch (CoreJudge.API)",
                ".NET Core Launch (Users.API)"
            ]
        }
    ]
}